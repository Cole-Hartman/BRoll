# Frontend (Vite) — copy to `.env.local` and adjust. Restart `npm run dev` after changes.

# Immich — REQUIRED for local dev (`npm run dev`). Without it, the app calls `/api/*` on Vite and gets HTML instead of JSON.
# Must match the Immich server you use in Settings (scheme + host + port).
# VITE_IMMICH_URL=http://192.168.1.11:30041

# FastAPI (transcription) — proxied at `/api-transcription`
# VITE_TRANSCRIPTION_API_URL=http://127.0.0.1:8000
# VITE_TRANSCRIPTION_API_URL=https://your-nas.example.com:8000

# If transcription URL uses HTTPS with a self-signed cert:
# VITE_TRANSCRIPTION_API_TLS_INSECURE=true
